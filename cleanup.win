#!/bin/sh
# Remove compiled object files from vendored MicroTeX sources (Windows)
find src/MicroTeX -name "*.o" -delete 2>/dev/null
rm -f src/*.o src/*.dll
# src/Makevars.win is generated by ./configure.win from Makevars.win.in; drop
# it so a re-install regenerates it against the current Rtools install.
rm -f src/Makevars.win
